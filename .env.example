# KrishiRakshak AI — Environment Variables Template
# Copy this file to .env and fill in your values

# ─── Backend Configuration ────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
BACKEND_URL=http://localhost:8000

# ─── Frontend Configuration ───────────────────────────────────────────────────
# In production, set this to your Render backend URL
# e.g. https://krishirakshak-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── AI / API Keys ────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey (free)
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: https://openweathermap.org/api (free tier)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── LangSmith Tracing (optional — for observability) ────────────────────────
# Get from: https://smith.langchain.com (free)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=KrishiRakshak

# ─── CORS (production) ────────────────────────────────────────────────────────
# Comma-separated list of extra allowed origins (beyond *.vercel.app)
# e.g. https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=
